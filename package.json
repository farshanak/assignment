{
  "name": "crud-api",
  "version": "1.0.0",
  "description": "Simple REST API with CRUD operations",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/",
    "test": "jest --forceExit --coverage",
    "test:tia": "node scripts/test-impact-analysis.js",
    "test:changed": "jest --changedSince=main --forceExit",
    "prepare": "pre-commit install || echo 'pre-commit not found, skipping hook install'"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
